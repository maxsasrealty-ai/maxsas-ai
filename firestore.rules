rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== HELPER FUNCTIONS =====
    function isAuthenticated() {
      return request.auth.uid != null;
    }

    function isCurrentUser(userId) {
      return request.auth.uid != null && request.auth.uid == userId;
    }

    function isAutomation() {
      // Automation writes must go through Admin SDK and bypass rules.
      return false;
    }

    function isGuestDemoUserId(userId) {
      return userId is string
        && userId.matches('^GUEST_[A-Za-z0-9_-]{3,120}$');
    }

    function batchExists(batchId) {
      return exists(/databases/$(database)/documents/batches/$(batchId));
    }

    function isBatchOwner(batchId) {
      return request.auth.uid != null &&
        get(/databases/$(database)/documents/batches/$(batchId)).data.userId
        == request.auth.uid;
    }

    function isValidLeadStatus(status) {
      return status in [
        'queued',
        'calling',
        'completed',
        'failed',
        'failed_retryable',
        'failed_permanent'
      ];
    }

    function isValidBatchStatus(status) {
      return status in ['pending', 'queued', 'running', 'scheduled', 'completed', 'failed'];
    }

    function isValidBatchSource(source) {
      return source in ['manual', 'csv', 'clipboard', 'image'];
    }

    function isValidAction(action) {
      return action in ['call_now', 'schedule'];
    }

    function isValidCallStatus(status) {
      return status in ['pending', 'in_progress', 'answered', 'failed', 'busy', 'unreachable', 'completed'];
    }

    function isValidAiDisposition(disposition) {
      return disposition in ['interested', 'callback_requested', 'meeting_scheduled', 'not_interested', 'follow_up', 'unknown', 'attempt_limit_reached', 'user_deleted'];
    }

    function approximatelyEqual(left, right, tolerance) {
      return left >= right - tolerance && left <= right + tolerance;
    }

    function isUserWalletTopUp(userId) {
      return isAuthenticated()
        && request.auth.uid == userId
        && request.resource.data.userId == userId
        && request.resource.data.balance is number
        && request.resource.data.balance >= 0
        && request.resource.data.lockedAmount is number
        && request.resource.data.lockedAmount >= 0
        && request.resource.data.lockedAmount <= request.resource.data.balance
        && request.resource.data.totalRecharged is number
        && request.resource.data.totalRecharged >= 0
        && request.resource.data.updatedAt != null
        && (resource == null || (
          request.resource.data.balance >= resource.data.balance
          && request.resource.data.totalRecharged >= resource.data.totalRecharged
          && request.resource.data.lockedAmount == resource.data.lockedAmount
          && request.resource.data.totalSpent == resource.data.totalSpent
        ));
    }

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    function isClientWalletBatchDebit(userId) {
      let previousLockedAmount = ('lockedAmount' in resource.data) ? resource.data.lockedAmount : 0;
      let previousTotalRecharged = ('totalRecharged' in resource.data) ? resource.data.totalRecharged : 0;
      let debitDeltaBalance = resource.data.balance - request.resource.data.balance;
      let debitDeltaSpent = request.resource.data.totalSpent - resource.data.totalSpent;
      return isAuthenticated()
        && request.auth.uid == userId
        && resource != null
        && request.resource.data.userId == userId
        && request.resource.data.balance is number
        && request.resource.data.balance >= 0
        && request.resource.data.totalSpent is number
        && request.resource.data.totalSpent >= 0
        && request.resource.data.lockedAmount is number
        && request.resource.data.lockedAmount >= 0
        && request.resource.data.lockedAmount <= request.resource.data.balance
        && request.resource.data.totalRecharged is number
        && request.resource.data.totalRecharged == previousTotalRecharged
        && (
          request.resource.data.lockedAmount == previousLockedAmount
          || (
            previousLockedAmount > request.resource.data.balance
            && request.resource.data.lockedAmount == request.resource.data.balance
          )
        )
        && request.resource.data.balance <= resource.data.balance
        && request.resource.data.totalSpent >= resource.data.totalSpent
        && debitDeltaBalance >= 0
        && debitDeltaSpent >= 0
        && approximatelyEqual(debitDeltaBalance, debitDeltaSpent, 0.01)
        && request.resource.data.updatedAt != null;
    }

    // ============================================================
    // USERS
    // Allows profile creation/updates during onboarding while protecting system fields
    // ============================================================
    match /users/{uid} {
      allow read: if isCurrentUser(uid) || isAdmin();
      allow create: if isCurrentUser(uid) && request.resource.data.userId == uid;
      allow update: if isCurrentUser(uid)
        && request.resource.data.userId == resource.data.userId
        && (isAutomation() 
            || !('currentActiveCalls' in resource.data)
            || !('currentActiveCalls' in request.resource.data)
            || request.resource.data.currentActiveCalls == resource.data.currentActiveCalls)
        && (isAutomation() 
            || !('tier' in resource.data)
            || !('tier' in request.resource.data)
            || request.resource.data.tier == resource.data.tier)
        && (isAutomation() 
            || !('maxCurrentCalls' in resource.data)
            || !('maxCurrentCalls' in request.resource.data)
            || request.resource.data.maxCurrentCalls == resource.data.maxCurrentCalls)
        && (isAutomation()
            || !('demoEligible' in resource.data)
            || !('demoEligible' in request.resource.data)
            || request.resource.data.demoEligible == resource.data.demoEligible
            || request.resource.data.demoEligible == false);
      allow delete: if false;
      match /notifications/{notificationId} {
        allow read: if isCurrentUser(uid);
        allow create, update: if isCurrentUser(uid)
          && request.resource.data.userId == uid
          && request.resource.data.dedupeKey is string
          && request.resource.data.type is string
          && request.resource.data.title is string
          && request.resource.data.body is string
          && request.resource.data.createdAt != null;
        allow delete: if false;
      }
    }


    // ============================================================
    // SYSTEM (Global Concurrency Control)
    // PHASE 2: Runtime configuration - Automation only
    // Users can read but not write
    // ============================================================
    match /system/runtime {
      allow read: if isAuthenticated() || isAutomation();
      allow write: if isAutomation();
    }

    // ============================================================
    // BATCHES
    // ============================================================
    match /batches/{batchId} {
      // User access
      allow read: if request.auth != null && resource.data.userId == request.auth.uid || isAdmin();
      allow write: if request.auth != null && resource.data.userId == request.auth.uid || isAdmin();
      // ...existing code for create/update/delete checks...
    }

    // ============================================================
    // LEADS
    // ============================================================
    match /leads/{leadId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid || isAdmin();
      // ...existing code for create/update/delete checks...
    }

    // ============================================================
    // WALLETS
    // Automation handles billing
    // ============================================================
    match /wallets/{userId} {

      allow read: if isAutomation() ||
        (isAuthenticated() && request.auth.uid == userId);

      allow create, update: if (
        (isAutomation()
          && request.resource.data.userId == userId
          && request.resource.data.balance is number
          && request.resource.data.balance >= 0
          && request.resource.data.lockedAmount is number
          && request.resource.data.lockedAmount >= 0
          && request.resource.data.lockedAmount <= request.resource.data.balance
          && request.resource.data.updatedAt != null)
        || isUserWalletTopUp(userId)
        || isClientWalletBatchDebit(userId)
      );

      allow delete: if false;

      // Subcollection: wallets/{userId}/transactions
      // Wallet service listens here for real-time ledger history.
      match /transactions/{transactionId} {
        allow read: if isAutomation() || (isAuthenticated() && request.auth.uid == userId);
        allow create: if isAuthenticated()
          && request.auth.uid == userId
          && request.resource.data.userId == userId
          && request.resource.data.transactionId == transactionId
          && request.resource.data.amount is number
          && request.resource.data.amount >= 0
          && request.resource.data.previousBalance is number
          && request.resource.data.previousBalance >= 0
          && request.resource.data.newBalance is number
          && request.resource.data.newBalance >= 0
          && (
            (
              request.resource.data.type == 'batch_debit'
              && approximatelyEqual(
                request.resource.data.newBalance,
                request.resource.data.previousBalance - request.resource.data.amount,
                0.01
              )
              && request.resource.data.batchId is string
            )
            || (
              request.resource.data.type == 'recharge'
              && approximatelyEqual(
                request.resource.data.newBalance,
                request.resource.data.previousBalance + request.resource.data.amount,
                0.01
              )
            )
          )
          && request.resource.data.createdAt != null;
        allow update, delete: if false;
      }
    }


    // ============================================================
    // DEFAULT DENY
    // ============================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
