# Google Sign-In Configuration
# Get these from Google Cloud Console: https://console.cloud.google.com/

# Expo OAuth 2.0 Client ID (used only when running inside Expo Go)
EXPO_PUBLIC_EXPO_CLIENT_ID=your-expo-client-id.apps.googleusercontent.com

# Web OAuth 2.0 Client ID (for web builds)
EXPO_PUBLIC_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Android OAuth 2.0 Client ID (for Android/EAS builds)
EXPO_PUBLIC_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

# iOS OAuth 2.0 Client ID (optional, for future iOS support)
EXPO_PUBLIC_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com

# Demo call webhook (MUST be HTTPS for web deployments like Vercel)
EXPO_PUBLIC_DEMO_CALL_WEBHOOK_URL=https://your-domain.com/webhook/ringg-init

# Retry lead webhook
EXPO_PUBLIC_RETRY_LEAD_WEBHOOK_URL=https://165.22.222.202:5678/webhook/retry-lead

# Razorpay server-side secrets (do not expose with EXPO_PUBLIC_ prefix)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxx

# Firebase Admin (server only) for secure webhook settlement writes
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

